<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sist.dao.food-mapper">
	<select id="foodFindData" resultType="FoodVO" parameterType="hashmap">
		SELECT no, name, poster, address, type
		FROM food
		WHERE ${column} LIKE '%'||#{ss}||'%'
		<!-- 
			추가 : prefix, suffix
			삭제 : prefixOverrides, suffixOverrides
			
			WHERE (type LIKE '%한식%') OR (type LIKE '%양식%')
			<input type=checkbox value="A" name="">한식
			{"A","B","",""}
		 -->
		 <if test="fdArr!=null">
		 AND
		<trim prefix="(" suffix=")" prefixOverrides="OR|AND">
		
			<foreach collection="fdArr" item="fd">
				<trim prefix="OR">
					<choose>
						<when test="fd=='A'.toString()">
							type LIKE '%한식%'
						</when>
						<when test="fd=='B'.toString()">
							type LIKE '%양식%'
						</when>
						<when test="fd=='C'.toString()">
							type LIKE '%일식%'
						</when>
						<when test="fd=='D'.toString()">
							type LIKE '%중식%'
						</when>
						<when test="fd=='E'.toString()">
							type LIKE '%분식%'
						</when>
					</choose>
				</trim>
			</foreach>
		
		</trim>
		</if>
		ORDER BY no ASC
		OFFSET #{start} ROWS FETCH NEXT 12 ROWS ONLY
	</select>
	<select id="foodFindCount" resultType="int" parameterType="hashmap">
		SELECT COUNT(*)
		FROM food
		WHERE ${column} LIKE '%'||#{ss}||'%'
		 <if test="fdArr!=null">
		 AND
		<trim prefix="(" suffix=")" prefixOverrides="OR|AND">
		
			<foreach collection="fdArr" item="fd">
				<trim prefix="OR">
					<choose>
						<when test="fd=='A'.toString()">
							type LIKE '%한식%'
						</when>
						<when test="fd=='B'.toString()">
							type LIKE '%양식%'
						</when>
						<when test="fd=='C'.toString()">
							type LIKE '%일식%'
						</when>
						<when test="fd=='D'.toString()">
							type LIKE '%중식%'
						</when>
						<when test="fd=='E'.toString()">
							type LIKE '%분식%'
						</when>
					</choose>
				</trim>
			</foreach>
		
		</trim>
		</if>
	</select>
</mapper>